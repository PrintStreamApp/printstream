{
  "name": "@printstream/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop tray bridge for connecting LAN Bambu printers to PrintStream.",
  "homepage": "https://github.com/RyanEwen/printstream",
  "author": {
    "name": "PrintStream",
    "email": "noreply@printstream.local"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file ../../.env ../../node_modules/.bin/tsx watch --include ../../packages/bridge-runtime/dist/**/*.js --include ../../packages/shared/dist/**/*.js src/index.ts",
    "package:update-bundle": "npm run build && node scripts/package-update-bundle.mjs",
    "package:update-bundle:api": "npm run build && node scripts/package-update-bundle.mjs --out-dir data/bridge-releases",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@printstream/bridge-runtime": "0.1.0",
    "@printstream/shared": "0.1.0",
    "dotenv": "^17.4.2",
    "mqtt": "^5.10.1",
    "ws": "^8.21.0",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/ws": "^8.5.13",
    "@types/yauzl": "^3.3.0",
    "@types/yazl": "^3.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
