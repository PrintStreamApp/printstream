// Prisma schema for printstream. PostgreSQL is the primary datastore for
// self-hosted deployments. Prefer migrations over `db push` once the schema
// is settled.

generator client {
  provider = "prisma-client-js"
  // The native single-file (SEA) self-hosted build has no Prisma CLI and no
  // download step at install time, so every shipping target's query engine must
  // be generated up front and embedded per build. `native` keeps the dev
  // container working; the rest cover the native single-file build's six targets
  // ({linux,darwin,win32} x {x64,arm64}).
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "darwin", "darwin-arm64", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  printers           Printer[]
  bridges            Bridge[]
  jobs               PrintJob[]
  dispatchJobs       DispatchJob[]
  libraryFiles       LibraryFile[]
  libraryFileVersions LibraryFileVersion[]
  libraryDownloadLinks LibraryDownloadLink[]
  libraryFolders     LibraryFolder[]
  libraryFileReplicas LibraryFileReplica[]
  libraryFileFavorites LibraryFileFavorite[]
  printerViews       PrinterView[]
  authMemberships    AuthTenantMembership[]
  authGroups         AuthGroup[]
  authServiceAccounts AuthServiceAccount[]
  orderTemplates     OrderTemplate[]
  orderTemplateVariants OrderTemplateVariant[]
  orderTemplatePrints OrderTemplatePrint[]
  orders             Order[]
  orderVariantSelections OrderVariantSelection[]
  orderPrints        OrderPrint[]
  filamentSpools     FilamentSpool[]
  filamentSpoolUsages FilamentSpoolUsage[]
  queueItems         QueueItem[]
  auditLogs          AuditLog[]
  stats              TenantStats?
  printerStats       PrinterStats[]

  @@unique([name])
}

model Printer {
  id         String   @id @default(cuid())
  tenantId   String
  bridgeId   String?
  name       String
  host       String
  serial     String
  accessCode String
  model      String   @default("unknown")
  currentPlateType String?
  currentNozzleDiameters String?
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bridge     Bridge?  @relation(fields: [bridgeId], references: [id], onDelete: SetNull)
  jobs       PrintJob[]
  dispatchJobs DispatchJob[]
  startedOrderPrints OrderPrint[] @relation("OrderPrintStartedPrinter")
  loadedFilamentSpools FilamentSpool[] @relation("FilamentSpoolLoadedPrinter")
  queueItemTargets   QueueItem[] @relation("QueueItemTargetPrinter")
  queueItemLastRuns  QueueItem[] @relation("QueueItemLastPrinter")

  @@unique([tenantId, serial])
  @@index([tenantId, bridgeId, position])
  @@index([tenantId, position])
}

model Bridge {
  id         String   @id @default(cuid())
  tenantId   String?
  name       String
  connectCode  String?  @unique
  runtimeTokenHash String?
  // Durable per-install identity the bridge persists across credential resets, so a
  // returning physical bridge re-binds to this row (keeping its printers and library)
  // instead of registering as a duplicate. High-entropy secret; never surfaced to the
  // browser. Contract: bridgeRuntimeRegistrationRequest in @printstream/shared.
  installationId String? @unique
  version    String?
  buildRevision String?
  sourceFingerprint String?
  releaseFingerprint String?
  protocolVersion Int?
  runnerAbiVersion String?
  updateChannel String @default("stable")
  updateStatus String?
  latestAvailableVersion String?
  lastUpdateCheckAt DateTime?
  lastUpdateError String?
  lastSeenAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant                Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  printers              Printer[]
  ownedLibraryFiles     LibraryFile[]       @relation("LibraryFileOwnerBridge")
  ownedLibraryFolders   LibraryFolder[]     @relation("LibraryFolderOwnerBridge")
  libraryFileReplicas   LibraryFileReplica[]

  @@index([tenantId, createdAt])
  @@index([runtimeTokenHash])
}

model PrintJob {
  id              String    @id @default(cuid())
  tenantId        String
  printerId       String
  taskId          String?
  printerFilePath String?
  jobName         String
  sourceType      String    @default("library")
  calibrationOption Int?
  fileId          String?
  fileName        String?
  fileSizeBytes   Int?
  plate           Int?
  useAms          Boolean?
  bedLevel        Boolean?
  amsMapping      String?
  progressPercent Int?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  durationSeconds Int?
  result          String    @default("unknown")
  thumbnailPath   String?
  snapshotPath    String?
  filamentUsedGrams Decimal? @db.Decimal(14, 3)
  filamentUsedMeters Decimal? @db.Decimal(14, 3)
  printerStatsRecordedAt DateTime?

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  printer         Printer   @relation(fields: [printerId], references: [id], onDelete: Cascade)
  file            LibraryFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  orderPrints     OrderPrint[] @relation("OrderPrintLastJob")
  queueItems      QueueItem[]  @relation("QueueItemLastJob")

  @@index([tenantId, printerId, startedAt])
  @@index([tenantId, printerId, finishedAt, startedAt])
  @@index([tenantId, printerId, taskId])
  @@index([tenantId, finishedAt, printerId])
  @@index([tenantId, fileId])
}

/// Durable journal of the print-dispatch lifecycle (queued -> uploading -> start
/// command -> sent/failed/cancelled). The live executor still runs in-process; this
/// row is written through on each transition so a restart can (a) reconcile orphaned
/// pre-start dispatches and (b) eventually be the cluster-wide source of truth for the
/// per-printer "one print starting at a time" guard. `startCommandAttemptedAt` is the
/// safety boundary: rows with it NULL provably never published a start (safe to clean
/// up); rows with it set may have started a real print and must be left to the
/// status recorder (see the dispatcher's rob-1 restart contract).
model DispatchJob {
  id                     String    @id
  tenantId               String
  printerId              String
  status                 String    @default("queued")
  jobName                String
  fileName               String
  /// Printer-SD file name the upload targets; used to clean orphaned bytes on reconnect.
  remoteName             String
  error                  String?
  /// Set immediately before the MQTT start command is published — the rob-1 boundary.
  startCommandAttemptedAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  finishedAt             DateTime?

  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  printer                Printer   @relation(fields: [printerId], references: [id], onDelete: Cascade)

  @@index([tenantId, printerId, status])
  @@index([printerId, status])
}

model TenantStats {
  tenantId            String   @id
  totalPrints         Int      @default(0)
  successfulPrints    Int      @default(0)
  failedPrints        Int      @default(0)
  cancelledPrints     Int      @default(0)
  successfulPrintDurationSeconds Int @default(0)
  failedPrintDurationSeconds Int @default(0)
  cancelledPrintDurationSeconds Int @default(0)
  wastedPrintDurationSeconds Int @default(0)
  trackedFilamentPrints Int    @default(0)
  filamentUsedGrams   Decimal  @default(0) @db.Decimal(14, 3)
  successfulFilamentUsedGrams Decimal @default(0) @db.Decimal(14, 3)
  failedFilamentUsedGrams Decimal @default(0) @db.Decimal(14, 3)
  cancelledFilamentUsedGrams Decimal @default(0) @db.Decimal(14, 3)
  wastedFilamentUsedGrams Decimal @default(0) @db.Decimal(14, 3)
  filamentUsedMeters  Decimal  @default(0) @db.Decimal(14, 3)
  successfulFilamentUsedMeters Decimal @default(0) @db.Decimal(14, 3)
  failedFilamentUsedMeters Decimal @default(0) @db.Decimal(14, 3)
  cancelledFilamentUsedMeters Decimal @default(0) @db.Decimal(14, 3)
  wastedFilamentUsedMeters Decimal @default(0) @db.Decimal(14, 3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PlatformStats {
  id                             String   @id
  tenantCount                    Int      @default(0)
  userCount                      Int      @default(0)
  printerCount                   Int      @default(0)
  totalPrints                    Int      @default(0)
  successfulPrintDurationSeconds Int      @default(0)
  failedPrintDurationSeconds     Int      @default(0)
  cancelledPrintDurationSeconds  Int      @default(0)
  wastedPrintDurationSeconds     Int      @default(0)
  trackedFilamentPrints          Int      @default(0)
  filamentUsedGrams              Decimal  @default(0) @db.Decimal(14, 3)
  successfulFilamentUsedGrams    Decimal  @default(0) @db.Decimal(14, 3)
  failedFilamentUsedGrams        Decimal  @default(0) @db.Decimal(14, 3)
  cancelledFilamentUsedGrams     Decimal  @default(0) @db.Decimal(14, 3)
  wastedFilamentUsedGrams        Decimal  @default(0) @db.Decimal(14, 3)
  filamentUsedMeters             Decimal  @default(0) @db.Decimal(14, 3)
  successfulFilamentUsedMeters   Decimal  @default(0) @db.Decimal(14, 3)
  failedFilamentUsedMeters       Decimal  @default(0) @db.Decimal(14, 3)
  cancelledFilamentUsedMeters    Decimal  @default(0) @db.Decimal(14, 3)
  wastedFilamentUsedMeters       Decimal  @default(0) @db.Decimal(14, 3)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model PrinterStats {
  tenantId              String
  printerSerial         String
  totalPrints           Int      @default(0)
  successfulPrints      Int      @default(0)
  failedPrints          Int      @default(0)
  cancelledPrints       Int      @default(0)
  successfulPrintDurationSeconds Int @default(0)
  failedPrintDurationSeconds Int @default(0)
  cancelledPrintDurationSeconds Int @default(0)
  wastedPrintDurationSeconds Int @default(0)
  trackedFilamentPrints Int      @default(0)
  filamentUsedGrams     Decimal  @default(0) @db.Decimal(14, 3)
  successfulFilamentUsedGrams Decimal @default(0) @db.Decimal(14, 3)
  failedFilamentUsedGrams Decimal @default(0) @db.Decimal(14, 3)
  cancelledFilamentUsedGrams Decimal @default(0) @db.Decimal(14, 3)
  wastedFilamentUsedGrams Decimal @default(0) @db.Decimal(14, 3)
  filamentUsedMeters    Decimal  @default(0) @db.Decimal(14, 3)
  successfulFilamentUsedMeters Decimal @default(0) @db.Decimal(14, 3)
  failedFilamentUsedMeters Decimal @default(0) @db.Decimal(14, 3)
  cancelledFilamentUsedMeters Decimal @default(0) @db.Decimal(14, 3)
  wastedFilamentUsedMeters Decimal @default(0) @db.Decimal(14, 3)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, printerSerial])
  @@index([tenantId, updatedAt])
}

model LibraryFile {
  id            String   @id @default(cuid())
  tenantId      String
  ownerBridgeId String?
  name          String
  storedPath    String
  sizeBytes     Int
  kind          String
  thumbnailPath String?
  uploadedAt    DateTime @default(now())
  currentVersionNumber Int @default(1)
  folderId      String?
  snapshotKey   String?  @unique
  // Hidden files are persisted on disk so previously-printed jobs can
  // still be re-dispatched, but they don't appear in the user-facing
  // library listing. Some hidden files are transient one-off uploads,
  // while others are immutable job snapshots retained for future
  // reprints. `snapshotKey` is only populated for the retained snapshot
  // variant; transient hidden files keep it null and are eligible for
  // periodic cleanup.
  hidden        Boolean  @default(false)
  // Recycle bin: soft-deleted files keep their bytes + version history and
  // stay restorable until the cleanup task hard-deletes them after the
  // retention window (LIBRARY_RECYCLE_RETENTION_DAYS).
  deletedAt     DateTime?
  // What created the row: 'upload' | 'slice' | 'scaffold' | 'snapshot'.
  // Null on rows created before origin tracking. Drives transient-file
  // cleanup (unsaved sliced outputs age out faster than uploads).
  origin        String?
  // Actor attribution for the current content (denormalized for display;
  // the audit log remains the authoritative record).
  createdById   String?
  createdByName String?
  // Set when the current content was produced by restoring an older
  // version; holds that source version's number.
  restoredFromVersionNumber Int?
  // Cached 3MF-derived display data (plateCount + plate-type/nozzle/filament/
  // compatible-model chips) so the library listing never re-inspects a file.
  // `derivedChipsJson` is the serialized chip bundle; `derivedChipsVersion` is the
  // parser version it was built with, so a parser bump invalidates it. Lazily
  // populated on inspect; null until first computed.
  derivedChipsJson    String?
  derivedChipsVersion Int?
  // Denormalized print-history rollup, maintained by the print-job recorder when a
  // print targeting this file is recorded (backfilled from PrintJob on migration).
  // Powers the "most printed" / "last printed" library sorts server-side so they
  // order correctly before the recency cap, without a per-listing PrintJob groupBy.
  printCount    Int      @default(0)
  lastPrintedAt DateTime?

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerBridge   Bridge?  @relation("LibraryFileOwnerBridge", fields: [ownerBridgeId], references: [id], onDelete: SetNull)
  folder        LibraryFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  replicas      LibraryFileReplica[]
  jobs          PrintJob[]
  versions      LibraryFileVersion[]
  downloadLinks LibraryDownloadLink[]
  favorites     LibraryFileFavorite[]
  orderTemplatePrints OrderTemplatePrint[]
  orderPrints   OrderPrint[]
  queueItems    QueueItem[]

  @@index([tenantId, uploadedAt])
  @@index([tenantId, folderId])
  @@index([tenantId, ownerBridgeId, folderId])
  @@index([tenantId, hidden, uploadedAt])
  @@index([tenantId, ownerBridgeId, folderId, name, hidden, uploadedAt])
  @@index([tenantId, deletedAt])
  // Backs the most-printed / last-printed sorts within a bridge folder.
  @@index([tenantId, ownerBridgeId, folderId, hidden, printCount], map: "LibraryFile_tenant_bridge_folder_printCount_idx")
  @@index([tenantId, ownerBridgeId, folderId, hidden, lastPrintedAt], map: "LibraryFile_tenant_bridge_folder_lastPrintedAt_idx")
}

/**
 * Per-user "favorite" star on a library file. Personal (not shared across the
 * workspace), so the row is keyed by `(userId, libraryFileId)`. `userId` is the
 * authenticated user id, or a fixed sentinel for no-auth/self-host installs where
 * the actor is anonymous — a non-null value keeps the unique constraint sound
 * (Postgres would otherwise allow duplicate NULL-user rows). Intentionally no FK to
 * AuthUser so favorites work in both auth-enabled (cloud) and no-auth installs;
 * cleanup rides on the LibraryFile / Tenant cascades.
 */
model LibraryFileFavorite {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  libraryFileId String
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  libraryFile LibraryFile @relation(fields: [libraryFileId], references: [id], onDelete: Cascade)

  @@unique([userId, libraryFileId])
  @@index([tenantId, userId])
  @@index([libraryFileId])
}

model LibraryFileVersion {
  id            String   @id @default(cuid())
  tenantId      String
  libraryFileId String
  ownerBridgeId String?
  folderId      String?
  name          String
  storedPath    String
  sizeBytes     Int
  kind          String   @default("other")
  thumbnailPath String?
  uploadedAt    DateTime
  versionNumber Int
  createdAt     DateTime @default(now())
  // Actor attribution + restore provenance, copied from the LibraryFile row
  // at the moment this version was archived.
  createdById   String?
  createdByName String?
  restoredFromVersionNumber Int?

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  libraryFile   LibraryFile @relation(fields: [libraryFileId], references: [id], onDelete: Cascade)

  @@unique([libraryFileId, versionNumber])
  @@index([tenantId, libraryFileId, versionNumber])
}

/**
 * Short-lived, unauthenticated download grant for a single library file.
 * Minted on demand (e.g. the "Open in Bambu Studio" desktop deep link) so an
 * external client with no browser session can fetch one file for a brief
 * window. Only the SHA-256 hash of the opaque token is stored; the raw token
 * lives only in the URL handed to the client. Rows are pruned opportunistically
 * once `expiresAt` passes.
 */
model LibraryDownloadLink {
  id            String   @id @default(cuid())
  tenantId      String
  libraryFileId String
  tokenHash     String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  createdById   String?

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  libraryFile   LibraryFile @relation(fields: [libraryFileId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([libraryFileId])
}

/**
 * User-organized folder tree for the library. Folders only group
 * `LibraryFile` rows; files are still stored flat on disk under
 * `LIBRARY_DIR` (the folder is purely a metadata grouping). A null
 * `parentId` is a top-level folder.
 */
model LibraryFolder {
  id        String   @id @default(cuid())
  tenantId  String
  ownerBridgeId String?
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerBridge Bridge?       @relation("LibraryFolderOwnerBridge", fields: [ownerBridgeId], references: [id], onDelete: SetNull)
  parent    LibraryFolder?  @relation("LibraryFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  LibraryFolder[] @relation("LibraryFolderTree")
  files     LibraryFile[]

  @@unique([tenantId, parentId, name])
  @@index([tenantId, ownerBridgeId, parentId])
  @@index([tenantId, parentId])
}

model LibraryFileReplica {
  id             String   @id @default(cuid())
  tenantId       String
  libraryFileId  String
  bridgeId       String
  storedPath     String
  contentHash    String?
  sizeBytes      Int
  replicaKind    String   @default("cache")
  status         String   @default("pending")
  lastVerifiedAt DateTime?
  lastAccessedAt DateTime?
  expiresAt      DateTime?
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  libraryFile    LibraryFile @relation(fields: [libraryFileId], references: [id], onDelete: Cascade)
  bridge         Bridge      @relation(fields: [bridgeId], references: [id], onDelete: Cascade)

  @@unique([libraryFileId, bridgeId])
  @@index([tenantId, bridgeId, status])
  @@index([tenantId, expiresAt])
}

model Setting {
  key   String @id
  value String
}

model PrinterView {
  id                   String   @id @default(cuid())
  tenantId             String
  name                 String
  printerIds           String?
  cardsPerRow          Int      @default(3)
  stateFilter          String   @default("all")
  modelFilter          String   @default("[]")
  nozzleDiameterFilter String   @default("[]")
  plateTypeFilter      String   @default("[]")
  sortKey              String   @default("name")
  sortDirection        String   @default("asc")
  group                String   @default("none")
  cardContentSettings  String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId, name])
}

/**
 * Externally installed plugins (uploaded archives or, eventually, store
 * downloads). Built-in plugins are not tracked here — they live in code
 * and use the `Setting` table for their install/enabled flags. An entry
 * here means the registry should dynamic-import `entryPath` (relative
 * to `installPath`) at startup and register the resulting `ApiPlugin`.
 */
model Plugin {
  name        String   @id
  version     String?
  description String?
  /** Where the package came from: 'upload' for now; 'store' is reserved. */
  source      String
  /** Absolute or env-rooted directory holding the extracted package. */
  installPath String
  /** ESM entry file relative to `installPath`. */
  entryPath   String
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuthUser {
  id            String                   @id @default(cuid())
  email         String
  displayName   String?
  isPlatformUser  Boolean                  @default(false)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  tenantMemberships AuthTenantMembership[]
  memberships   AuthUserGroupMembership[]
  passkeys      AuthPasskeyCredential[]
  passwordCredential AuthPasswordCredential?
  emailCodeTokens AuthEmailCodeToken[]
  sessions      AuthSession[]
  auditLogs     AuditLog[]

  @@unique([email])
  @@index([email])
  @@index([createdAt])
}

model AuthTenantMembership {
  userId        String
  tenantId      String
  loginDisabled Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, loginDisabled])
}

model AuthGroup {
  id          String                            @id @default(cuid())
  tenantId    String?
  key         String?
  name        String
  description String?
  permissions String[]
  isSystem    Boolean                           @default(false)
  isEditable  Boolean                           @default(true)
  isRemovable Boolean                           @default(true)
  createdAt   DateTime                          @default(now())
  updatedAt   DateTime                          @updatedAt

  tenant                    Tenant?                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userMemberships           AuthUserGroupMembership[]
  serviceAccountMemberships AuthServiceAccountGroupMembership[]

  @@unique([tenantId, key])
  @@unique([tenantId, name])
  @@index([tenantId, key])
  @@index([tenantId, createdAt])
}

model AuthUserGroupMembership {
  userId    String
  groupId   String
  createdAt DateTime  @default(now())

  user      AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     AuthGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
}

model AuthServiceAccount {
  id          String                             @id @default(cuid())
  tenantId    String
  name        String
  tokenHash   String                             @unique
  tokenPrefix String                             @unique
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime                           @default(now())
  updatedAt   DateTime                           @updatedAt

  tenant      Tenant                             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships AuthServiceAccountGroupMembership[]
  sessions    AuthSession[]
  auditLogs   AuditLog[]

  @@index([tenantId, createdAt])
  @@index([tenantId, revokedAt])
}

model AuthServiceAccountGroupMembership {
  serviceAccountId String
  groupId          String
  createdAt        DateTime           @default(now())

  serviceAccount   AuthServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  group            AuthGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([serviceAccountId, groupId])
  @@index([groupId])
}

model AuthPasskeyCredential {
  id             String    @id @default(cuid())
  userId         String
  credentialId   String    @unique
  publicKey      Bytes
  transports     String[]
  counter        Int       @default(0)
  aaguid         String?
  backedUp       Boolean   @default(false)
  nickname       String?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// One email/password credential per user, owned by the OSS `auth-password`
// provider. `passwordHash` is an algorithm-tagged, salted hash (argon2id, or a
// scrypt fallback) — never a reversible secret. `mustChangePassword` is set when
// an admin sets/resets the password and cleared on the user's next self-change.
model AuthPasswordCredential {
  id                  String    @id @default(cuid())
  userId              String    @unique
  passwordHash        String
  mustChangePassword  Boolean   @default(false)
  // One-time email password-reset code (SHA-256 hash) + expiry. Only populated
  // while a reset is pending and when an email transport is configured; cleared
  // on use. Reset-by-email is an optional capability — the provider works without it.
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  lastChangedAt       DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthEmailCodeToken {
  id         String    @id @default(cuid())
  userId      String?
  email      String
  tokenHash  String    @unique
  redirectTo String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user       AuthUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, expiresAt])
  @@index([userId, expiresAt])
  @@map("AuthMagicLinkToken")
}

model AuthSession {
  id               String               @id @default(cuid())
  secretHash       String               @unique
  userId           String?
  serviceAccountId String?
  userAgent        String?
  expiresAt        DateTime
  lastSeenAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime             @default(now())

  user             AuthUser?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAccount   AuthServiceAccount?  @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([serviceAccountId, expiresAt])
  @@index([revokedAt])
}

model AuditLog {
  id                 String               @id @default(cuid())
  tenantId           String?
  actorType          String
  actorUserId        String?
  actorServiceAccountId String?
  actorLabel         String?
  requestMethod      String
  requestPath        String
  action             String
  resource           String
  summary            String
  statusCode         Int
  ipAddress          String?
  metadataJson       String?
  createdAt          DateTime             @default(now())

  tenant             Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser          AuthUser?            @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorServiceAccount AuthServiceAccount? @relation(fields: [actorServiceAccountId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([actorServiceAccountId, createdAt])
  @@index([action, createdAt])
}

model OrderTemplate {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  code          String?
  description   String?
  notesTemplate String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants      OrderTemplateVariant[]
  orders        Order[]

  @@index([tenantId, name])
  @@index([tenantId, createdAt])
}

model OrderTemplateVariant {
  id            String   @id @default(cuid())
  tenantId      String
  templateId    String
  name          String
  position      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template      OrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items         OrderTemplatePrint[]
  orderSelections OrderVariantSelection[]
  orderPrints   OrderPrint[]

  @@index([tenantId, templateId, position])
}

model OrderTemplatePrint {
  id              String   @id @default(cuid())
  tenantId        String
  templateVariantId String
  libraryFileId   String?
  libraryFileName String
  plate           Int
  quantity        Int
  notes           String?
  position        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant         OrderTemplateVariant @relation(fields: [templateVariantId], references: [id], onDelete: Cascade)
  libraryFile     LibraryFile?        @relation(fields: [libraryFileId], references: [id], onDelete: SetNull)
  orderPrints     OrderPrint[]

  @@index([tenantId, templateVariantId, position])
  @@index([tenantId, libraryFileId])
}

model Order {
  id                  String   @id @default(cuid())
  tenantId            String
  templateId          String?
  templateName        String
  templateCode        String?
  templateDescription String?
  name                String
  notes               String?
  status              String   @default("active")
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template            OrderTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  selectedVariants    OrderVariantSelection[]
  prints              OrderPrint[]

  @@index([tenantId, templateId])
  @@index([tenantId, status, createdAt])
}

model OrderVariantSelection {
  id                 String   @id @default(cuid())
  tenantId           String
  orderId            String
  templateVariantId  String?
  templateVariantName String
  quantity           Int
  position           Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order              Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  templateVariant    OrderTemplateVariant? @relation(fields: [templateVariantId], references: [id], onDelete: SetNull)

  @@index([tenantId, orderId, position])
  @@index([tenantId, templateVariantId])
}

model OrderPrint {
  id                 String    @id @default(cuid())
  tenantId           String
  orderId            String
  templatePrintId    String?
  templateVariantId  String?
  templateVariantName String?
  projectFilamentOverrides Json?
  libraryFileId      String?
  libraryFileName    String
  plate              Int
  notes              String?
  groupPosition      Int
  sequenceNumber     Int
  sequenceCount      Int
  status             String    @default("pending")
  completionSource   String?
  attemptCount       Int       @default(0)
  startedPrinterId   String?
  startedAt          DateTime?
  lastPrintJobId     String?
  lastPrintResult    String?
  lastPrintFinishedAt DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order              Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  templatePrint      OrderTemplatePrint? @relation(fields: [templatePrintId], references: [id], onDelete: SetNull)
  templateVariant    OrderTemplateVariant? @relation(fields: [templateVariantId], references: [id], onDelete: SetNull)
  libraryFile        LibraryFile?       @relation(fields: [libraryFileId], references: [id], onDelete: SetNull)
  startedPrinter     Printer?           @relation("OrderPrintStartedPrinter", fields: [startedPrinterId], references: [id], onDelete: SetNull)
  lastPrintJob       PrintJob?          @relation("OrderPrintLastJob", fields: [lastPrintJobId], references: [id], onDelete: SetNull)

  @@index([tenantId, orderId, groupPosition, sequenceNumber])
  @@index([tenantId, status, startedAt])
  @@index([tenantId, templateVariantId])
  @@index([tenantId, libraryFileId])
  @@index([tenantId, startedPrinterId])
  @@index([tenantId, lastPrintJobId])
}

/// A physical filament spool tracked in a workspace's inventory (the
/// `filament-manager` plugin). Bambu RFID spools are auto-added on AMS insert and
/// keyed by `bambuUuid`; other spools are entered manually. `remainingGrams` is
/// the canonical "amount left": synced from the printer's reported remain% for
/// Bambu spools, decremented from per-job consumption for the rest (see
/// `FilamentSpoolUsage`). Tenant-scoped, soft-deletable (recycle) and separately
/// archivable (used up but kept for history), mirroring `LibraryFile`.
model FilamentSpool {
  id              String    @id @default(cuid())
  tenantId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  // Recycle bin: restorable until the retention window hard-deletes the row.
  deletedAt       DateTime?
  // Retired / used up but intentionally kept for history; still listable under a filter.
  archivedAt      DateTime?

  // Material identity
  brand           String?
  filamentType    String                          // PLA, PETG, ABS, ...
  materialSubtype String?                          // e.g. "PLA Silk", "PLA Basic"
  colorName       String?                          // resolved or custom display name
  colorHex        String?                          // primary color, #RRGGBB
  colorsJson      String?                          // multi-color palette as JSON #RRGGBB[]
  // Preset / RFID identity
  trayInfoIdx     String?                          // Bambu filament preset id (e.g. "GFA00")
  bambuUuid       String?                          // RFID serial (tray_uuid); auto-add dedupe key
  serial          String?                          // manual serial for non-Bambu spools
  nozzleTempMin   Int?
  nozzleTempMax   Int?
  diameterMm      Float     @default(1.75)

  // Quantity tracking
  netWeightGrams  Int       @default(1000)         // full-spool net filament weight
  spoolCoreGrams  Int?                             // empty core weight, for scale-based measuring
  remainingGrams  Float     @default(1000)         // canonical amount left
  remainSource    String    @default("manual")     // 'printer' | 'tracked' | 'manual'

  // Provenance / cost
  costCents       Int?
  currency        String?
  purchasedAt     DateTime?
  vendor          String?
  notes           String?

  // Current location: which printer/slot it is loaded into, if any.
  loadedPrinterId String?
  loadedAmsId     Int?                             // AMS unit id, or 254/255 for external virtual trays
  loadedSlotId    Int?                             // slot within the AMS unit; null for external spools
  loadedAt        DateTime?
  lastSeenAt      DateTime?                         // last time confirmed present in a slot

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loadedPrinter   Printer?  @relation("FilamentSpoolLoadedPrinter", fields: [loadedPrinterId], references: [id], onDelete: SetNull)
  usage           FilamentSpoolUsage[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, filamentType])
  @@index([tenantId, brand])
  @@index([tenantId, loadedPrinterId])
  // bambuUuid is not unique: a recycled/archived row may share the RFID of a
  // re-added spool, so auto-add dedupes among non-deleted rows in app code.
  @@index([tenantId, bambuUuid])
}

/// Append-only consumption ledger for a spool: one row per print that drew from
/// it (`source: 'print'`), per manual correction (`'manual'`), or per RFID
/// remain% resync (`'rfid-sync'`). `jobId` is a soft reference to `PrintJob`
/// (kept even if that row is later pruned) so usage history survives, mirroring
/// how production stats are not reverted on job deletion.
model FilamentSpoolUsage {
  id          String    @id @default(cuid())
  tenantId    String
  spoolId     String
  jobId       String?
  grams       Float
  source      String    @default("print")          // 'print' | 'manual' | 'rfid-sync'
  note        String?
  recordedAt  DateTime  @default(now())

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spool       FilamentSpool @relation(fields: [spoolId], references: [id], onDelete: Cascade)

  @@index([tenantId, spoolId, recordedAt])
  @@index([tenantId, jobId])
}

/// A queued print waiting to be dispatched (the `print-queue` plugin). One shared,
/// reorderable workspace backlog: each item targets any eligible printer by default
/// but can be pinned to a specific printer or printer model ("Any X1C"). `quantity`/
/// `completedCount` track first-class copies — the row counts down rather than being
/// exploded into N rows. `requiredFilamentsJson` snapshots the plate's required
/// filaments at add time so eligibility/AMS matching needs no per-list 3MF inspection.
/// v1 is manual-dispatch only; auto-advance is a deliberate later phase. `status` is the
/// dispatch lifecycle (queued|held|dispatching|printing|done|failed); per-printer
/// eligibility is computed live (not persisted) from the shared matcher.
model QueueItem {
  id                    String   @id @default(cuid())
  tenantId              String
  libraryFileId         String?
  fileName              String
  // Source kind for display: 'gcode' | '3mf'.
  kind                  String   @default("gcode")
  // 1-based plate index inside a multi-plate 3MF.
  plateIndex            Int      @default(1)
  plateName             String?
  // First-class copies: the row stays queued until completedCount reaches quantity.
  quantity              Int      @default(1)
  completedCount        Int      @default(0)
  // Fractional rank for cheap drag-reorder without renumbering siblings.
  sortKey               Float    @default(0)
  // Hybrid targeting: 'any' | 'printer' | 'model'.
  targetKind            String   @default("any")
  targetPrinterId       String?
  targetModel           String?
  // Serialized PrintFromLibrary print options (useAms, bedLevel, flowCalibration, ...).
  printOptionsJson      String?
  // Optional manual tray override; the matcher computes one at dispatch when null.
  amsMappingJson        String?
  // Snapshot of the plate's required filaments ([{id,filamentType,color}]) at add time.
  requiredFilamentsJson String?
  // Snapshot of the file's compatible printer models (JSON string[]) at add time; the
  // matcher rejects printers whose model isn't compatible (sliced gcode is machine-specific).
  compatibleModelsJson  String?
  // Snapshot of the plate's bed/plate type and nozzle diameters (JSON string[]) at add time,
  // for display in the queue list (matches what the file would show when printed).
  plateType             String?
  nozzleDiametersJson   String?
  status                String   @default("queued")
  label                 String?
  createdById           String?
  // Optional link to the order print this item was queued for (the orders plugin).
  // Plain ids, no FK: a stale link (order/print deleted) is handled gracefully as a
  // no-op. When set, adding/removing/dispatching this item is mirrored onto the order
  // print via the printerEvents bus (the orders plugin listens) — no cross-plugin import.
  orderId               String?
  orderPrintId          String?
  // Most recent dispatch attempt — printer + tracked PrintJob linkage for completion
  // reconciliation and history (mirrors OrderPrint's last-print columns).
  lastPrinterId         String?
  lastDispatchJobId     String?
  lastPrintJobId        String?
  lastJobName           String?
  lastResult            String?
  lastDispatchedAt      DateTime?
  lastFinishedAt        DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  libraryFile           LibraryFile? @relation(fields: [libraryFileId], references: [id], onDelete: SetNull)
  targetPrinter         Printer?     @relation("QueueItemTargetPrinter", fields: [targetPrinterId], references: [id], onDelete: SetNull)
  lastPrinter           Printer?     @relation("QueueItemLastPrinter", fields: [lastPrinterId], references: [id], onDelete: SetNull)
  lastPrintJob          PrintJob?    @relation("QueueItemLastJob", fields: [lastPrintJobId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, sortKey])
  @@index([tenantId, sortKey])
  @@index([tenantId, libraryFileId])
  @@index([tenantId, targetPrinterId])
  @@index([tenantId, lastPrinterId])
  @@index([tenantId, lastPrintJobId])
  @@index([tenantId, orderPrintId])
}
