{
  "name": "@printstream/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "predev": "npm run build --workspace @printstream/shared",
    "dev": "tsx watch --include \"../../packages/shared/dist/**\" --include \"../../packages/bridge-runtime/dist/**\" src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:db:push": "prisma db push",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:baseline": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/baseline.sql",
    "db:reset-auth": "tsx scripts/dev/reset-auth.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@printstream/bridge-runtime": "0.1.0",
    "@printstream/shared": "0.1.0",
    "@prisma/client": "^6.5.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "basic-ftp": "^5.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "embedded-postgres": "^18.4.0-beta.17",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "marked": "^18.0.6",
    "mqtt": "^5.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "occt-import-js": "^0.0.23",
    "pg": "^8.16.0",
    "pngjs": "^7.0.0",
    "undici": "^7.25.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "yauzl": "^3.3.0",
    "yazl": "^3.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "@types/pngjs": "^6.0.5",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3"
  }
}
