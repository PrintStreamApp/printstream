# Copy this file to .env on a bridge-only host.

# PrintStream server URL the bridge should register with.
BRIDGE_SERVER_URL=https://your-printstream-server.example.com

# Optional overrides (everything has a default — see docs/configuration.md for
# the full overridable list):
# BRIDGE_NAME=Store
# DISCOVERY_PORT=2021
# CAMERA_DEBUG_LOGS=false