{
  "name": "@printstream/bridge-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "package.json",
    "!dist/**/*.test.*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@printstream/shared": "0.1.0",
    "basic-ftp": "^5.3.0",
    "mqtt": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14"
  }
}