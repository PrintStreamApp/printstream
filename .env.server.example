# Copy this file to .env for a PrintStream server deployment.
#
# Only the vars a deployment usually sets are listed here. Everything else has a
# working default — see docs/configuration.md for the full
# overridable list. (The bridge data paths are pinned to /data/... by
# compose.server.example.yml, so they are not repeated here.)

# API
DATABASE_URL=postgresql://postgres:postgres@db:5432/printstream?schema=public
CLIENT_ORIGIN=http://localhost:8080
# Absolute base URL of this API (used for media links in notifications).
PUBLIC_BASE_URL=http://localhost:8080
# Master key for encrypting stored secrets at rest (e.g. OAuth client secrets).
# Set to any long random string for a real deployment; leaving it unset stores
# those settings unencrypted. Rotating it makes previously-encrypted secrets
# unreadable (re-enter them in Settings).
SECRETS_KEY=

# Shared bearer token between the API and the slicer service. The slicer spawns
# native CLI binaries on uploaded input; with this empty it runs WITHOUT auth and
# must stay on a private/internal-only network (the default compose does). Set a
# long random string — wired to both the api and slicer services — before
# exposing the slicer beyond its internal network.
SLICER_SERVICE_TOKEN=

# PrintStream server URL the bridge registers with (defaults to the `api`
# service on the same network; change to http://localhost:4000 when the
# bridge runs outside Docker).
BRIDGE_SERVER_URL=http://api:4000

# Managed bridge is ON by default for this single-host setup: the bundled
# bridge auto-pairs into your workspace on first start and the Bridges settings
# page is hidden — nothing to configure, no secret, no pairing step. To run
# multiple bridges or a bridge on another machine instead, uncomment the line
# below and pair from Settings > Bridges using the connect code it logs.
# MANAGED_BRIDGE=false

# Local auth one-time email code delivery (optional).
# Uses Cloudflare Email Sending. Leave the account/token blank to keep email
# delivery unconfigured. Rotate tokens if they are ever shared in chat, logs,
# screenshots, or other non-secret channels.
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM_EMAIL=
CLOUDFLARE_EMAIL_FROM_NAME=PrintStream

# Notifications (optional)
NTFY_TOPIC_URL=

# Observability / metrics (optional). Off by default. When enabled, the API
# exposes a Prometheus /metrics endpoint on METRICS_PORT for an INTERNAL scraper
# (do not publish that port). The compose.observability.example.yml overlay sets
# these for you and stands up Prometheus + Grafana. See docs/observability.md.
# METRICS_ENABLED=true
# METRICS_PORT=9464
